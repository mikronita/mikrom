# mikrom-network environment configuration
NATS_URL=nats://[::1]:4222
RUST_LOG=info
MIKROM_HOST_ID=node-1
MIKROM_DATA_DIR=/var/lib/mikrom-network
MIKROM_WG_PORT=51823
MIKROM_ADVERTISE_ADDRESS=fd00::2

# Observability
ENABLE_TELEMETRY=true
DT_API_URL=http://[::1]:4318/api/v2/otlp
# DT_API_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://[::1]:4318/api/v2/otlp
