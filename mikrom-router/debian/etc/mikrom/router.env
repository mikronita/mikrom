# mikrom-router environment configuration
NATS_URL=nats://[fd00::2]:4222
RUST_LOG=info

DATABASE_URL=postgres://mikrom:mikrom_password@[fd00::2]:5432/mikrom_router
STATE_CACHE_PATH=/var/lib/mikrom/router-state.json
# Use Let's Encrypt production so api.mikrom.spluca.org gets a valid certificate.
ACME_STAGING=false
API_HOST=api.mikrom.spluca.org
API_UPSTREAM_URL=http://[::1]:5001
DASHBOARD_HOST=dashboard.mikrom.spluca.org
DASHBOARD_UPSTREAM_URL=http://[::1]:3000
DEFAULT_SITE_HOST=debaser.spluca.org
DEFAULT_SITE_REDIRECT_URL=https://spluca.org/
ROUTER_ADVERTISE_ADDRESS=fd00::1
ROUTER_WG_PORT=51821
MASTER_KEY=mikrom-super-secret-key-123-and-is-as-least-32-characters-long
# PINGORA_CONF=/etc/mikrom/pingora.conf
