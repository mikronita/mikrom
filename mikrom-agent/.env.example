# mikrom-agent environment variables
NATS_URL=nats://localhost:4222
TEST_NATS_URL=nats://localhost:4223
# AGENT_ID= (optional, will be generated if not set)
# LOG_LEVEL=info
USE_TLS=false
BRIDGE_IP=10.0.0.1/8
CERTS_DIR=/certs/agent
AGENT_HOSTNAME=
HOST_ID=

# Observability
ENABLE_TELEMETRY=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_FORMAT=json
